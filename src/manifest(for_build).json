{
    "manifest_version": 3,
    "name": "TupTest",
    "version": "1.2",
    "description": "Useful tools for the site smartest.bg",
    "action": {
        "default_popup": "popup.html"
    },

    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },

    "content_scripts": [
        {
            "matches": ["https://www.smartest.bg/session/*"],
            "js": ["content.js"],
            "css": ["styles.css"],
            "run_at": "document_start"
        }
    ],

    "web_accessible_resources": [
        {
            "resources": ["inject.js", "spoof.js"],
            "matches": ["https://www.smartest.bg/*"]
        }
    ],

    "permissions": ["storage", "clipboardWrite"],

    "host_permissions": ["https://openrouter.ai/*"]
}
